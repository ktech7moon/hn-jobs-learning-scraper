# Python
.venv/
__pycache__/
*.pyc
*.pyo
build/
dist/
*.egg-info/
.pytest_cache/
.ruff_cache/

# Secrets and env
.env
.env.local

# Logs and databases
*.db
*.log

# Project data — local-only telemetry and digests
data/*
!data/.gitkeep
!data/logs/
data/logs/*
