# Sample HTML may contain real HN content; only synthetic, labeled
# .json or .md fixtures are committed.
samples/*.html

# Editors
.vscode/
.idea/

# OS
.DS_Store

# Claude Code per-machine local overrides
.claude/settings.local.json
