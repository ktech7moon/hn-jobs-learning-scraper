# Python
.venv/
__pycache__/
*.pyc
*.pyo
build/
dist/
*.egg-info/
.pytest_cache/
.ruff_cache/

# Secrets and env
.env
.env.local

# Logs and databases
*.db
*.log

# Project data — local-only telemetry; digests are published artifacts
data/*
!data/.gitkeep
!data/logs/
data/logs/*
!data/logs/.gitkeep
# Publish digest outputs so README "Real output" links resolve.
# Telemetry (data/logs/) and learning artifacts (data/learning/) stay local.
!data/digests/
!data/digests/*.md

# Throwaway scratch
scratch/*
!scratch/.gitkeep

# Sample HTML may contain real HN content; only synthetic, labeled
# .json or .md fixtures are committed.
samples/*.html

# Editors
.vscode/
.idea/

# OS
.DS_Store

# Claude Code per-machine local overrides
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/skills/

# Browserbase / agentskills installs (npx skills add ...) — local tool, not project source
.agents/

# Autobrowse training workspace — created by the learning loop, contains run-specific artifacts
autobrowse/
